{
  "name": "@apitrail/cli",
  "version": "0.1.0",
  "description": "CLI for apitrail — init schema, inspect, drop.",
  "license": "MIT",
  "author": "apitrail contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osharim/apitrail.git",
    "directory": "packages/cli"
  },
  "homepage": "https://apitrail.io",
  "bugs": "https://github.com/osharim/apitrail/issues",
  "keywords": ["apitrail", "cli", "postgres"],
  "type": "module",
  "bin": {
    "apitrail": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@apitrail/postgres": "workspace:*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
