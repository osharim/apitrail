{
  "name": "@apitrail/postgres",
  "version": "0.1.0",
  "description": "Postgres storage adapter for apitrail",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apitrail/apitrail.git",
    "directory": "packages/postgres"
  },
  "homepage": "https://apitrail.io",
  "keywords": ["apitrail", "postgres", "postgresql", "adapter", "storage", "supabase"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "apitrail": "workspace:*",
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "apitrail": "workspace:*",
    "pg": "^8.13.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
