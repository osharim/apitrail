{
  "name": "@apitrail/postgres",
  "version": "0.1.0-alpha.4",
  "description": "Store your API logs in Postgres. The official Postgres storage adapter for apitrail — edge-safe, lazy-loaded, works with Supabase / Neon / RDS / self-hosted. One table, smart indexes, zero config.",
  "license": "MIT",
  "author": "apitrail contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osharim/apitrail.git",
    "directory": "packages/postgres"
  },
  "homepage": "https://apitrail.io",
  "bugs": "https://github.com/osharim/apitrail/issues",
  "keywords": [
    "apitrail",
    "postgres",
    "postgresql",
    "adapter",
    "storage",
    "supabase",
    "neon",
    "rds",
    "logging",
    "observability",
    "nextjs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "@apitrail/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "@apitrail/core": "workspace:*"
  }
}
