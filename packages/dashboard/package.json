{
  "name": "@apitrail/dashboard",
  "version": "0.1.0-alpha.4",
  "description": "Embed a production-ready API-logs dashboard directly into your Next.js app. Drop-in Server Component with KPIs, request explorer, and waterfall detail view. One route mount, auth-callback ready, ships its own CSS.",
  "license": "MIT",
  "author": "apitrail contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osharim/apitrail.git",
    "directory": "packages/dashboard"
  },
  "homepage": "https://apitrail.io",
  "bugs": "https://github.com/osharim/apitrail/issues",
  "keywords": [
    "apitrail",
    "dashboard",
    "nextjs",
    "observability",
    "ui",
    "server-components",
    "embed",
    "admin",
    "logs-viewer",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": ["*.css"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "pg": ">=8.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "next": "^15.1.3",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
