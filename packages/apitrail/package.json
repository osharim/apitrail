{
  "name": "apitrail",
  "version": "0.1.0",
  "description": "The API logger for Next.js (and beyond) — your data, your database.",
  "license": "MIT",
  "author": "apitrail contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osharim/apitrail.git",
    "directory": "packages/apitrail"
  },
  "homepage": "https://apitrail.io",
  "bugs": "https://github.com/osharim/apitrail/issues",
  "keywords": [
    "nextjs",
    "next",
    "logger",
    "api-logger",
    "observability",
    "telemetry",
    "opentelemetry",
    "otel",
    "vercel",
    "tracing"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/console": {
      "types": "./dist/adapters/console.d.ts",
      "import": "./dist/adapters/console.js",
      "require": "./dist/adapters/console.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "peerDependencies": {
    "next": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@vercel/otel": "^2.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
